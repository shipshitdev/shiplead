{
  "name": "@shiplead/monorepo",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "deps:update": "bunx npm-check-updates -u --deep && bun install",
    "dev": "turbo run dev --filter=@shiplead/desktop",
    "dev:all": "turbo run dev",
    "dev:api": "turbo run dev --filter=@shiplead/api",
    "dev:desktop": "turbo run dev --filter=@shiplead/desktop",
    "dev:web": "turbo run dev --filter=@shiplead/web",
    "format:check": "bunx biome check . --linter-enabled=false --assist-enabled=false --files-ignore-unknown=true",
    "lint": "turbo run lint",
    "lint:fix": "bunx biome check --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "0.28.0",
    "sass": "^1.99.0",
    "turbo": "2.9.6",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
